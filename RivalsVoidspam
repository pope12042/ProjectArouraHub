MainFrame.BackgroundColor3 = Color3.fromRGB(12, 12, 18)
MainFrame.Position = UDim2.new(0.5, -100, 0.4, -50)
MainFrame.Size = UDim2.new(0, 210, 0, 360) -- Increased size for new inputs
