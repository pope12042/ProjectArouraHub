-- Toggle visibility on re-execution

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Check if GUI already exists and toggle with animation
local existingGui = playerGui:FindFirstChild("ExecutorSettingsGUI")
if existingGui then
    local existingFrame = existingGui:FindFirstChild("MainFrame")
    if existingFrame then
        if existingGui.Enabled then
            -- Slide out animation
            TweenService:Create(existingFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                Position = UDim2.new(0.5, 0, 1.5, 0)
            }):Play()
            wait(0.3)
            existingGui.Enabled = false
        else
            existingGui.Enabled = true
            existingFrame.Position = UDim2.new(0.5, 0, 1.5, 0)
            TweenService:Create(existingFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Position = UDim2.new(0.5, -350, 0.5, -90)
            }):Play()
        end
    end
    return
end

